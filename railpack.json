{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        "python -m venv /app/.venv",
        "pip install -r requirements.txt",
        "python -m playwright install --with-deps chromium"
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn backend.main:app --host 0.0.0.0 --port $PORT"
  }
}
